+const TASK_TERMINAL_STATUSES = new Set(['accepted', 'transferred', 'cancelled']);
+const TASK_ACTIVE_STATUSES = new Set(['pending_ack', 'acknowledged', 'in_progress', 'submitted', 'needs_review']);
+
+function getTaskStatusSummary(assignees = []) {
+    const active = assignees.filter(a => !['transferred', 'cancelled'].includes(a.status));
+    const counts = active.reduce((acc, a) => {
+        acc[a.status] = (acc[a.status] || 0) + 1;
+        return acc;
+    }, {});
+    const total = active.length;
+    const engaged = active.filter(a => a.status !== 'pending_ack').length;
+    const completed = active.filter(a => a.status === 'accepted').length;
+    const unique = Object.keys(counts);
+    return {
+        counts,
+        total,
+        engaged,
+        completed,
+        engagementPct: total ? Math.round((engaged / total) * 100) : 0,
+        completionPct: total ? Math.round((completed / total) * 100) : 0,
+        state: total === 0 ? 'empty' : (unique.length === 1 ? unique[0] : 'mixed')
+    };
+}
+
+function getTaskStateLabel(state) {
+    return ({
+        empty: 'No Active Assignees',
+        mixed: 'Mixed Progress',
+        pending_ack: 'Needs Acknowledgement',
+        acknowledged: 'Acknowledged',
+        in_progress: 'In Progress',
+        submitted: 'Pending Review',
+        needs_review: 'Changes Needed',
+        accepted: 'Completed',
+        transferred: 'Transferred',
+        cancelled: 'Cancelled'
+    })[state] || 'Unknown';
+}
